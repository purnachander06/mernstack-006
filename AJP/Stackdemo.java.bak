import java.util.*;
public class Stackdemo {
	public static void main(String[]args){
		String st = "madam";
		Stack<Character> stack = new Stack<>();
		for(char ch: st.tocharArray()){
			stack.push(ch);
		}
		String rev = " ";
		while(!stack.isEmpty()){
			rev += stack.pop();
		}
	    if(st.equals(rev)){
			System.out.println("Palindrome");
		}else{
			System.out.println("Not Palindrome");
		}
	}
}